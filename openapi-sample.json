{
  "openapi": "3.0.0",
  "info": {
    "title": "PetstoreAPI",
    "version": "1.0.0",
    "description": "Sample Petstore spec for testing SDKGenerator locally."
  },
  "servers": [
    { "url": "https://petstore.swagger.io/v2" }
  ],
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/pets": {
      "get": {
        "summary": "List pets",
        "operationId": "listPets",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Pet" }
                }
              }
            }
          }
        }
      }
    }
  }
}
